OPENAI_API_KEY=your-openai-api-key-here
TAVILY_API_KEY=your-tavily-api-key-here

# YouTube Data API v3 — get a key at https://console.cloud.google.com
# Enable "YouTube Data API v3" in your project, then create an API key.
# Default quota: 10,000 units/day. search.list costs 100 units/call — cache aggressively.
YOUTUBE_API_KEY=

# Optional: pre-verified YouTube channel IDs for trusted source families.
# Leave blank until you have confirmed the official channel_id via the API or YouTube Studio.
# Do NOT guess 24-character channel IDs — set them only after verification.
YOUTUBE_CHANNEL_HUBERMAN=
YOUTUBE_CHANNEL_SCHOOL_OF_GREATNESS=
YOUTUBE_CHANNEL_TIM_FERRISS=
YOUTUBE_CHANNEL_DIARY_OF_CEO=
YOUTUBE_CHANNEL_RICH_ROLL=
YOUTUBE_CHANNEL_MODERN_WISDOM=
YOUTUBE_CHANNEL_IMPACT_THEORY=
YOUTUBE_CHANNEL_TED=
